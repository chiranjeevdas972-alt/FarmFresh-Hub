rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'phone', 'subject', 'message', 'status', 'createdAt'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && data.phone is string && data.phone.size() > 0 && data.phone.size() <= 30
        && data.subject is string && data.subject.size() > 0 && data.subject.size() <= 250
        && data.message is string && data.message.size() > 0 && data.message.size() <= 5000
        && data.status in ['new', 'contacted', 'closed']
        && data.createdAt == request.time;
    }

    match /otp_verification/{docId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(request.resource.data);
      allow read, update, delete: if request.auth != null;
    }

    match /contactInquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Default catch-all for development if needed, but keeping it secure
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
