rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Only authenticated users can read/write
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                    && request.resource.size < 10 * 1024 * 1024 // Limit upload to 10MB
                    && (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('application/pdf') || request.resource.contentType.matches('video/.*'));
    }
  }
}
